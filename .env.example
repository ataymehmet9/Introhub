# ==============================================
# INTROHUB ENVIRONMENT VARIABLES
# ==============================================
# Copy this file to .env.local for local development
# For production, set these in your deployment platform
# ==============================================
APP_URL=http://localhost:3000

# ==============================================
# DATABASE
# ==============================================
# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/introhub"

# ==============================================
# BETTER AUTH
# ==============================================
# Base URL for your application (no trailing slash)
# Local: http://localhost:3000
# Production: https://yourdomain.com
BETTER_AUTH_URL="http://localhost:3000"
VITE_BETTER_AUTH_URL="http://localhost:3000"

# Secret key for Better Auth (generate with: openssl rand -hex 32)
BETTER_AUTH_SECRET="your-secret-key-here"

# ==============================================
# OAUTH PROVIDERS
# ==============================================

# LinkedIn OAuth
# Get credentials from: https://www.linkedin.com/developers/
# Redirect URL: {BETTER_AUTH_URL}/api/auth/callback/linkedin
LINKEDIN_CLIENT_ID="your-linkedin-client-id"
LINKEDIN_CLIENT_SECRET="your-linkedin-client-secret"

# Microsoft OAuth
# Get credentials from: https://portal.azure.com/
# Redirect URL: {BETTER_AUTH_URL}/api/auth/callback/microsoft
MICROSOFT_CLIENT_ID="your-microsoft-client-id"
MICROSOFT_CLIENT_SECRET="your-microsoft-client-secret"

# Google OAuth
# Get credentials from: https://console.cloud.google.com/
# Redirect URL: {BETTER_AUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID="your-microsoft-client-id"
GOOGLE_CLIENT_SECRET="your-microsoft-client-secret"

# ==============================================
# EMAIL SERVICE (RESEND)
# ==============================================
# Get API key from: https://resend.com/
RESEND_API_KEY="your-resend-api-key"

# ==============================================
# FILE UPLOAD (BETTER UPLOAD - AWS S3)
# ==============================================
# AWS S3 credentials for Better Upload
# Get from: https://aws.amazon.com/console/
# Required IAM permissions: s3:PutObject, s3:GetObject, s3:DeleteObject

# AWS Access Key ID
BETTER_UPLOAD_ACCESS_KEY="your-aws-access-key-id"

# AWS Secret Access Key
BETTER_UPLOAD_SECRET_KEY="your-aws-secret-access-key"

# S3 Bucket Name (must be created in AWS)
VITE_BETTER_UPLOAD_BUCKET_NAME="your-bucket-name"

# AWS Region (e.g., us-east-1, ap-southeast-2, eu-west-1)
VITE_BETTER_UPLOAD_BUCKET_REGION="ap-southeast-2"

# ==============================================
# MONITORING (SENTRY)
# ==============================================
# Get from: https://sentry.io/

# Sentry DSN (Data Source Name)
VITE_SENTRY_DSN="your-sentry-dsn"

# Sentry Organization ID
VITE_SENTRY_ORG="your-sentry-org-id"

# Sentry Project Name
VITE_SENTRY_PROJECT="your-sentry-project"

# Sentry Auth Token (for source maps upload)
SENTRY_AUTH_TOKEN="your-sentry-auth-token"

# ==============================================
# DOCKER COMPOSE (OPTIONAL)
# ==============================================
# These are used by docker-compose.yml

# PostgreSQL Configuration
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="postgres"
POSTGRES_DB="introhub"
POSTGRES_PORT="5432"

# ==============================================
# ANALYTICS (POSTHOG)
# ==============================================
# Get from: https://posthog.com/
# Create a project and copy the API key from Project Settings

# PostHog Project API Key (required)
VITE_PUBLIC_POSTHOG_KEY="phc_your_project_api_key_here"

# PostHog Host URL (required)
# Use https://app.posthog.com for PostHog Cloud
# Or your self-hosted URL: https://posthog.yourdomain.com
VITE_PUBLIC_POSTHOG_HOST="https://app.posthog.com"

# PostHog Defaults (optional)
# JSON string for default PostHog configuration
VITE_PUBLIC_POSTHOG_DEFAULTS=""

# Application Port
APP_PORT="3000"

# ==============================================
# NOTES
# ==============================================
# 1. NEVER commit .env.local or .env files to version control
# 2. All VITE_* variables are exposed to the client-side code
# 3. Non-VITE_* variables are server-side only
# 4. For production, use your platform's environment variable system
#    (e.g., Vercel, Railway, AWS, etc.)
# 5. Generate secure secrets using: openssl rand -hex 32
# ==============================================
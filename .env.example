# ==============================================
# INTROHUB ENVIRONMENT VARIABLES
# ==============================================
# Copy this file to .env.local for local development
# For production, set these in your deployment platform
# ==============================================
APP_URL=http://localhost:3000

# ==============================================
# DATABASE
# ==============================================
# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/introhub"

# ==============================================
# BETTER AUTH
# ==============================================
# Base URL for your application (no trailing slash)
# Local: http://localhost:3000
# Production: https://yourdomain.com
BETTER_AUTH_URL="http://localhost:3000"
VITE_BETTER_AUTH_URL="http://localhost:3000"

# Secret key for Better Auth (generate with: openssl rand -hex 32)
BETTER_AUTH_SECRET="your-secret-key-here"

# ==============================================
# OAUTH PROVIDERS
# ==============================================

# LinkedIn OAuth
# Get credentials from: https://www.linkedin.com/developers/
# Redirect URL: {BETTER_AUTH_URL}/api/auth/callback/linkedin
LINKEDIN_CLIENT_ID="your-linkedin-client-id"
LINKEDIN_CLIENT_SECRET="your-linkedin-client-secret"

# Microsoft OAuth
# Get credentials from: https://portal.azure.com/
# Redirect URL: {BETTER_AUTH_URL}/api/auth/callback/microsoft
MICROSOFT_CLIENT_ID="your-microsoft-client-id"
MICROSOFT_CLIENT_SECRET="your-microsoft-client-secret"

# Google OAuth
# Get credentials from: https://console.cloud.google.com/
# Redirect URL: {BETTER_AUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ==============================================
# EMAIL SERVICE (RESEND)
# ==============================================
# Get API key from: https://resend.com/
RESEND_API_KEY="your-resend-api-key"

# ==============================================
# FILE UPLOAD (BETTER UPLOAD - AWS S3)
# ==============================================
# AWS S3 credentials for Better Upload
# Get from: https://aws.amazon.com/console/
# Required IAM permissions: s3:PutObject, s3:GetObject, s3:DeleteObject

# AWS Access Key ID
BETTER_UPLOAD_ACCESS_KEY="your-aws-access-key-id"

# AWS Secret Access Key
BETTER_UPLOAD_SECRET_KEY="your-aws-secret-access-key"

# S3 Bucket Name (must be created in AWS)
VITE_BETTER_UPLOAD_BUCKET_NAME="your-bucket-name"

# AWS Region (e.g., us-east-1, ap-southeast-2, eu-west-1)
VITE_BETTER_UPLOAD_BUCKET_REGION="ap-southeast-2"

# ==============================================
# MONITORING (SENTRY)
# ==============================================
# Get from: https://sentry.io/

# Sentry DSN (Data Source Name)
VITE_SENTRY_DSN="your-sentry-dsn"

# Sentry Organization ID
VITE_SENTRY_ORG="your-sentry-org-id"

# Sentry Project Name
VITE_SENTRY_PROJECT="your-sentry-project"

# Sentry Auth Token (for source maps upload)
SENTRY_AUTH_TOKEN="your-sentry-auth-token"

# ==============================================
# DOCKER COMPOSE (OPTIONAL)
# ==============================================
# These are used by docker-compose.yml

# PostgreSQL Configuration
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="postgres"
POSTGRES_DB="introhub"
POSTGRES_PORT="5432"

# Redis Configuration
REDIS_PORT="6379"

# ==============================================
# REDIS
# ==============================================
# Redis connection URL for BullMQ job queue
# Local: redis://localhost:6379
# Production: Use your managed Redis URL (Upstash, Redis Cloud, etc.)
REDIS_URL="redis://localhost:6379"

# ==============================================
# CRM INTEGRATIONS
# ==============================================
# HubSpot OAuth Configuration
# Get credentials from: https://developers.hubspot.com/
# 1. Create an app in HubSpot Developer Portal
# 2. Add OAuth scopes: crm.objects.contacts.read, crm.objects.contacts.write
# 3. Set redirect URI: {APP_URL}/api/crm/hubspot/callback

# HubSpot Client ID (also exposed to client for OAuth redirect)
HUBSPOT_CLIENT_ID="your-hubspot-client-id"
VITE_HUBSPOT_CLIENT_ID="your-hubspot-client-id"

# HubSpot Client Secret (server-side only)
HUBSPOT_CLIENT_SECRET="your-hubspot-client-secret"

# HubSpot Redirect URI (must match the one in HubSpot app settings)
HUBSPOT_REDIRECT_URI="http://localhost:3000/api/crm/hubspot/callback"

# ==============================================
# ENCRYPTION
# ==============================================
# Encryption key for storing sensitive data (OAuth tokens)
# Generate with: openssl rand -hex 32
# IMPORTANT: Keep this secret and never commit to version control
ENCRYPTION_KEY="your-encryption-key-here"

# ==============================================
# ANALYTICS (POSTHOG)
# ==============================================
# Get from: https://posthog.com/
# Create a project and copy the API key from Project Settings

# PostHog Project API Key (required)
# Used for both analytics and OpenTelemetry logging
VITE_PUBLIC_POSTHOG_KEY="phc_your_project_api_key_here"

# PostHog Host URL (required)
# Use https://app.posthog.com for PostHog Cloud (US)
# Use https://eu.i.posthog.com for PostHog Cloud (EU)
# Or your self-hosted URL: https://posthog.yourdomain.com
VITE_PUBLIC_POSTHOG_HOST="https://app.posthog.com"

# PostHog Defaults (optional)
# JSON string for default PostHog configuration
VITE_PUBLIC_POSTHOG_DEFAULTS=""

# ==============================================
# OPENTELEMETRY LOGGING (POSTHOG)
# ==============================================
# OpenTelemetry logs are sent to PostHog for centralized observability
# Uses the same PostHog credentials as analytics above

# PostHog Project Token (optional - falls back to VITE_PUBLIC_POSTHOG_KEY)
# Only set this if you want to use a different token for logging
POSTHOG_PROJECT_TOKEN=""

# Service Name for OpenTelemetry (optional)
# Identifies your service in PostHog logs
OTEL_SERVICE_NAME="introhub-api"

# Log Level (optional)
# Options: debug, info, warn, error
# Default: info
OTEL_LOG_LEVEL="info"

# Application Port
APP_PORT="3000"

# ==============================================
# STRIPE PAYMENTS
# ==============================================
# Get from: https://dashboard.stripe.com/
# 1. Create a product in Stripe Dashboard
# 2. Create a recurring price for the product
# 3. Copy the Price ID (starts with price_)
# 4. Set up webhook endpoint: {APP_URL}/api/billing/webhook
# 5. Copy webhook signing secret (starts with whsec_)

# Stripe Secret Key (from API keys section)
STRIPE_SECRET_KEY="your-stripe-secret-key"

# Stripe Price ID for Pro Plan (from Products section)
# Example: price_1234567890abcdefghijklmn
STRIPE_PRO_PRICE_ID="your-stripe-price-id"

# Stripe Webhook Secret (from Webhooks section)
# Example: whsec_1234567890abcdefghijklmn
STRIPE_WEBHOOK_SECRET="your-stripe-webhook-secret"

# ==============================================
# NOTES
# ==============================================
# 1. NEVER commit .env.local or .env files to version control
# 2. All VITE_* variables are exposed to the client-side code
# 3. Non-VITE_* variables are server-side only
# 4. For production, use your platform's environment variable system
#    (e.g., Vercel, Railway, AWS, etc.)
# 5. Generate secure secrets using: openssl rand -hex 32

# ==============================================
# AI GENERATION (GROQ - FREE TIER)
# ==============================================
# Get from: https://console.groq.com/keys
# Sign up for free at https://console.groq.com/
# No credit card required for free tier (14,400 requests/day)

# Groq API Key (required for AI-powered introduction messages)
GROQ_API_KEY="gsk_your_groq_api_key_here"

# AI Configuration (optional - defaults provided)
AI_MODEL="llama-3.3-70b-versatile"
AI_MAX_TOKENS="500"
AI_TEMPERATURE="0.7"

# Rate Limiting (optional - default: 10 generations per hour)
AI_RATE_LIMIT_PER_HOUR="10"
# ==============================================